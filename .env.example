# Site URL - set to your deployed Vercel URL in production
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# fal.ai
FAL_KEY=

# Random string used to HMAC-sign webhook callbacks from fal.ai
WEBHOOK_SECRET=

# Optional: cap free generations per user per 24h
DAILY_GENERATION_LIMIT=10
