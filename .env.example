# Site URL - set to your deployed Vercel URL in production
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Generation provider API key
FAL_KEY=

# Random string used to HMAC-sign webhook callbacks from the generation provider
WEBHOOK_SECRET=

# Optional: cap free generations per user per 24h
DAILY_GENERATION_LIMIT=10

# Optional: site-wide access password. When set, visitors must enter this once
# (at /gate) before they can reach the app or the sign-in page. Leave unset to
# disable the gate.
APP_ACCESS_PASSWORD=
