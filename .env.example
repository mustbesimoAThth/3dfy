# Site URL - set to your deployed Vercel URL in production
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Generation provider API key
FAL_KEY=

# Random string used to HMAC-sign webhook callbacks from the generation provider
WEBHOOK_SECRET=

# Optional: cap free generations per user per 24h
DAILY_GENERATION_LIMIT=10

# Access gate (shared sign-in). Visitors enter APP_ACCESS_PASSWORD at /gate and
# are signed into the single shared Supabase account below. The Supabase user
# SHARED_ACCOUNT_EMAIL must exist with its password set to APP_ACCESS_PASSWORD
# and its email confirmed. Both must be set for the app to be reachable.
APP_ACCESS_PASSWORD=
SHARED_ACCOUNT_EMAIL=
