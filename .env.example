# Site URL - set to your deployed Vercel URL in production
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Generation provider API key
FAL_KEY=

# Random string used to HMAC-sign webhook callbacks from the generation provider
WEBHOOK_SECRET=

# Optional: cap free generations per user per 24h
DAILY_GENERATION_LIMIT=10

# Access gate (shared sign-in). Visitors enter APP_ACCESS_PASSWORD at /gate and
# are signed into a shared Supabase account with email studio@app.local. In Supabase,
# create a user with that email and password set to the value of APP_ACCESS_PASSWORD
# (email confirmed). This is the only required env var for the app to be reachable.
APP_ACCESS_PASSWORD=
